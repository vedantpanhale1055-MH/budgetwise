# ============================================================
# BudgetWise — Environment Variables Template
# ============================================================
#
# INSTRUCTIONS:
# 1. Copy this file and rename the copy to: .env
#    (the .env file is gitignored — safe, never committed)
# 2. Fill in your real values from Supabase
# 3. The Groq API key is entered by users inside the app
#    Settings modal — it is NOT stored here
#
# HOW TO GET YOUR SUPABASE VALUES:
# 1. Go to https://supabase.com and open your project
# 2. Click "Project Settings" → "API"
# 3. Copy "Project URL" → paste as VITE_SUPABASE_URL
# 4. Copy "anon public" key → paste as VITE_SUPABASE_ANON_KEY
# ============================================================


# ── Supabase ─────────────────────────────────────────────────
VITE_SUPABASE_URL=https://your-project-id.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key-here


# ── App config (optional — defaults shown) ───────────────────
VITE_APP_NAME=BudgetWise
VITE_APP_VERSION=1.0.0


# ============================================================
# NOTE: Groq API key is NOT stored here.
# Users paste their own Groq key in the app's Settings modal.
# It is stored in localStorage on their device only.
# This keeps the project safe to push to GitHub publicly.
# ============================================================
